{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "declaration": false,
    "composite": false,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "vscode"]
  },
  "references": [
    { "path": "../core" },
    { "path": "../kb" },
    { "path": "../llm" },
    { "path": "../agents" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
